<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:NOTATerminal.ViewModels" 
        mc:Ignorable="d"
		xmlns:bh="using:NOTATerminal.Behaviors"
        x:Class="NOTATerminal.Views.GridTerminal"
	    x:DataType="vm:GridTerminalViewModel">
	<Grid DockPanel.Dock="Top" Grid.Row="2" RowDefinitions="0.9*, 0.1*" ColumnDefinitions="*" HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
		<!--xmlns:console="using:Iciclecreek.Terminal"-->
		<!--<console:TerminalView></console:TerminalView>-->
	</Grid>
</UserControl>

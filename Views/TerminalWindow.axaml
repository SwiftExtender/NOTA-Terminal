<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:NOTATerminal.ViewModels"
        mc:Ignorable="d"
	    xmlns:console="using:Iciclecreek.Terminal"
		xmlns:bh="using:NOTATerminal.Behaviors"
        x:Class="NOTATerminal.Views.Terminal"
	    x:DataType="vm:TerminalViewModel">
	<Grid DockPanel.Dock="Top" RowDefinitions="0.9*, 0.1*" ColumnDefinitions="*" HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
		<console:TerminalView Grid.Row="0" x:Name="Term"/>
		<DockPanel Grid.Row="1" >
			<SelectableTextBlock/>
		</DockPanel>
	</Grid>
</UserControl>
<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:NOTATerminal.ViewModels"
        mc:Ignorable="d"
	    xmlns:console="using:Iciclecreek.Terminal"
		xmlns:bh="using:NOTATerminal.Behaviors"
        x:Class="NOTATerminal.Views.TerminalCustomControl"
	    x:DataType="vm:TerminalViewModel"
	    x:Name="TerminalWindow">
	<Grid DockPanel.Dock="Top" RowDefinitions="0.9*, 0.1*" ColumnDefinitions="*" HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
		<console:CustomTerminalControl Grid.Row="0" x:Name="TabTerminal" FontFamily="Cascadia Mono"
                FontSize="14" BufferSize="100000" Unloaded=""/>
		<TextBox Grid.Row="1" Watermark="Command"></TextBox>
	</Grid>
</UserControl>